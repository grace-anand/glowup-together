# ─── Sentry (Error Monitoring) ───────────────────────────────────────────────
# https://sentry.io → Settings → Projects → Your Project → Client Keys (DSN)
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
# https://sentry.io → Settings → Auth Tokens (for source map uploads)
SENTRY_AUTH_TOKEN=

# ─── Neon / Drizzle (Database) ──────────────────────────────────────────────
# https://console.neon.tech → Connection Details → Connection string
DATABASE_URL=
# Pooled connection (for serverless, optional)
DATABASE_URL_POOLER=

# ─── Clerk (Managed Authentication) ─────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=
